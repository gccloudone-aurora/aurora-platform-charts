                    app.kubernetes.io/component: system
                    app.kubernetes.io/part-of: priority-classes
                    app.kubernetes.io/managed-by: argo
                    helm.sh/chart: aurora-core-0.0.1
                value: 800000
                globalDefault: false
              - apiVersion: scheduling.k8s.io/v1
                kind: PriorityClass
